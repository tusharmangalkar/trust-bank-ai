{
  "manifest_version": 3,
  "name": "Trust Fintech RAG (NEW RETAIL)",
  "description": "AI Banking Assistant with Azure Permanent RAG (50 Documents) and Voice Input/Output.",
  "version": "1.0",
  "icons": {
    "16": "trust_logo16.png",
    "48": "trust_logo48.png",
    "128": "trust_logo128.png"
  },
  "action": {
    "default_popup": "chat.html",  
    "default_icon": {
      "16": "trust_logo16.png",
      "48": "trust_logo48.png",
      "128": "trust_logo128.png"
    }
  },
  "permissions": ["storage"], 
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}